# 模型配置
LLM_PROVIDER=local
PROFESSIONAL_MODEL_PATH=./model/deepseek-r1-7B
LIVING_MODEL_PATH=./model/qwen-chat-7b

# DashScope (阿里云)
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_MODEL=qwen-plus

# OpenAI 兼容 API
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# RAG
RAG_DATA_ROOT=./rag/datasets
RAG_VECTOR_STORE_PATH=./rag/vector_store
RAG_CHUNK_SIZE=300
RAG_CHUNK_OVERLAP=50

# 混合检索
HYBRID_VECTOR_WEIGHT=0.6
HYBRID_BM25_WEIGHT=0.4
HYBRID_SEARCH_K=5

# 重排序
ENABLE_RERANKER=true
RERANKER_MODEL=BAAI/bge-reranker-base
RERANKER_TOP_N=3

# 服务
HOST=0.0.0.0
PORT=8000
