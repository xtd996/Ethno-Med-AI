# ── LLM 提供商 ──
# "local"    → vLLM/SGLang/TGI 等本地推理框架（OpenAI 兼容 API）
# "dashscope" → 阿里云 DashScope
# "openai"    → OpenAI 或任何兼容 API
LLM_PROVIDER=local

# ── 本地模型推理服务（vLLM / SGLang / TGI）──
LOCAL_MODEL_BASE_URL=http://localhost:8001/v1
LOCAL_MODEL_API_KEY=not-needed
PROFESSIONAL_MODEL_NAME=deepseek-r1-7b
LIVING_MODEL_NAME=qwen-chat-7b
# 模型权重目录（docker-compose 挂载用）
MODEL_PATH=./model

# ── DashScope (阿里云) ──
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_MODEL=qwen-plus

# ── OpenAI 兼容 API ──
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# RAG
RAG_DATA_ROOT=./rag/datasets
RAG_VECTOR_STORE_PATH=./rag/vector_store
RAG_CHUNK_SIZE=300
RAG_CHUNK_OVERLAP=50

# 混合检索
HYBRID_VECTOR_WEIGHT=0.6
HYBRID_BM25_WEIGHT=0.4
HYBRID_SEARCH_K=5

# 重排序
ENABLE_RERANKER=true
RERANKER_MODEL=BAAI/bge-reranker-base
RERANKER_TOP_N=3

# 服务
HOST=0.0.0.0
PORT=8000
